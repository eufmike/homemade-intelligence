# =============================================================================
# Homemade Intelligence — .gitignore
# =============================================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ----- Virtual environments -----
.venv/
venv/
ENV/
env/
.conda/

# ----- Pixi -----
.pixi/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- IDE & editors -----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Environment & secrets -----
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ----- OS files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ----- Logs -----
*.log
logs/

# ----- Data & caches -----
*.cache
.cache/
.mypy_cache/
.ruff_cache/
*.sqlite3
*.db

# ----- Reports — generated drafts (keep published versions) -----
# Uncomment below to ignore generated draft reports:
# reports/**/draft-*

# ----- Temporary files -----
tmp/
temp/
*.tmp

# ----- Runtime data (generated) -----
data/
!data/.gitkeep

# ----- Node.js (frontend) -----
frontend/node_modules/
frontend/.next/
frontend/out/
